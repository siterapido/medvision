#!/bin/bash
# Script para rodar frontend e backend juntos

# Function to cleanup processes on exit
cleanup() {
    echo ""
    echo "Parando serviços..."

    # Matar frontend
    if [ ! -z "$FRONTEND_PID" ]; then
        echo "Parando frontend (PID: $FRONTEND_PID)..."
        kill $FRONTEND_PID 2>/dev/null || true
    fi

    # Matar backend
    if [ ! -z "$BACKEND_PID" ]; then
        echo "Parando backend (PID: $BACKEND_PID)..."
        kill $BACKEND_PID 2>/dev/null || true
    fi

    # Limpar portas
    echo "Limpando portas 3000 e 8000..."
    lsof -ti :3000 | xargs kill -9 2>/dev/null || true
    lsof -ti :8000 | xargs kill -9 2>/dev/null || true

    echo "Serviços parados."
    exit 0
}

# Set trap to cleanup on SIGINT (Ctrl+C) or SIGTERM
trap cleanup SIGINT SIGTERM

# Cores para output
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE}Odonto GPT - Development Environment${NC}"
echo -e "${BLUE}========================================${NC}"
echo ""

# Limpar portas se estiverem ocupadas
echo -e "${YELLOW}Limpando portas 3000 e 8000...${NC}"
lsof -ti :3000 | xargs kill -9 2>/dev/null || true
lsof -ti :8000 | xargs kill -9 2>/dev/null || true
sleep 1

# ========================================
# BACKEND (Agno Service)
# ========================================
echo -e "${YELLOW}Starting Backend (Agno Service)...${NC}"

cd odonto-gpt-agno-service

# Check if venv exists, create if not
if [ ! -d "venv" ]; then
    echo "Creating virtual environment..."
    python3 -m venv venv
fi

# Activate virtual environment
source venv/bin/activate

# Install dependencies if needed
if [ ! -f ".installed" ] || [ "requirements.txt" -nt ".installed" ]; then
    echo "Installing Python dependencies..."
    pip install -q -r requirements.txt
    touch .installed
fi

# Verifica se existe arquivo .env
if [ ! -f ".env" ]; then
    echo -e "${YELLOW}AVISO: Arquivo .env não encontrado em odonto-gpt-agno-service/${NC}"
    echo -e "${YELLOW}Criando .env a partir de .env.example...${NC}"
    if [ -f ".env.example" ]; then
        cp .env.example .env
        echo -e "${YELLOW}Por favor, edite odonto-gpt-agno-service/.env com suas credenciais${NC}"
    fi
fi

# Voltar para diretório raiz
cd ..

# Start backend em background
cd odonto-gpt-agno-service
source venv/bin/activate
python -m uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload > ../backend.log 2>&1 &
BACKEND_PID=$!
cd ..

echo -e "${GREEN}✓ Backend rodando na porta 8000 (PID: $BACKEND_PID)${NC}"
sleep 2

# Verificar se o backend iniciou corretamente
if ! kill -0 $BACKEND_PID 2>/dev/null; then
    echo -e "${YELLOW}✗ Erro ao iniciar backend. Verifique backend.log${NC}"
    cat backend.log
    cleanup
    exit 1
fi

# ========================================
# FRONTEND (Next.js)
# ========================================
echo -e "${YELLOW}Starting Frontend (Next.js)...${NC}"

# Verificar se node_modules existe
if [ ! -d "node_modules" ]; then
    echo "Installing Node dependencies..."
    npm install
fi

# Verificar se .env.local existe
if [ ! -f ".env.local" ]; then
    echo -e "${YELLOW}AVISO: Arquivo .env.local não encontrado${NC}"
    if [ -f ".env.example" ]; then
        echo -e "${YELLOW}Criando .env.local a partir de .env.example...${NC}"
        cp .env.example .env.local
        echo -e "${YELLOW}Por favor, edite .env.local com suas credenciais${NC}"
    fi
fi

# Start frontend em background
npm run dev > frontend.log 2>&1 &
FRONTEND_PID=$!

echo -e "${GREEN}✓ Frontend rodando na porta 3000 (PID: $FRONTEND_PID)${NC}"
sleep 2

# Verificar se o frontend iniciou corretamente
if ! kill -0 $FRONTEND_PID 2>/dev/null; then
    echo -e "${YELLOW}✗ Erro ao iniciar frontend. Verifique frontend.log${NC}"
    cat frontend.log
    cleanup
    exit 1
fi

# ========================================
# READY
# ========================================
echo ""
echo -e "${GREEN}========================================${NC}"
echo -e "${GREEN}✓ Serviços iniciados com sucesso!${NC}"
echo -e "${GREEN}========================================${NC}"
echo ""
echo -e "${BLUE}Frontend:${NC}    http://localhost:3000"
echo -e "${BLUE}Backend (API):${NC} http://localhost:8000"
echo -e "${BLUE}API Docs:${NC}    http://localhost:8000/docs"
echo ""
echo -e "${YELLOW}Logs:${NC}"
echo -e "  Frontend: tail -f frontend.log"
echo -e "  Backend:  tail -f backend.log"
echo ""
echo -e "${YELLOW}Pressione Ctrl+C para parar ambos os serviços${NC}"
echo ""

# Wait for both processes
wait $FRONTEND_PID $BACKEND_PID
