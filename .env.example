# -----------------------------------------------------------------------------
# MedVision — copie para .env.local e use credenciais do SEU projeto Supabase
# -----------------------------------------------------------------------------

# Supabase (novo projeto — não reutilize URLs/chaves de outro app)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

NEXT_PUBLIC_SITE_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Bunny CDN (crie storage/zona para este projeto)
BUNNY_STORAGE_ZONE=your_storage_zone
BUNNY_STORAGE_API_KEY=your_bunny_api_key
BUNNY_CDN_BASE_URL=https://your-pull-zone.b-cdn.net/
BUNNY_STORAGE_HOST=storage.bunnycdn.com
NEXT_PUBLIC_MAX_ATTACHMENT_MB=1500

# Z-API WhatsApp — https://app.z-api.io/
Z_API_INSTANCE_ID=your_instance_id_here
Z_API_TOKEN=your_token_here
Z_API_CLIENT_TOKEN=your_client_token_here

# IA (OpenRouter / Perplexity)
OPENROUTER_API_KEY=
OPENROUTER_MODEL_RESEARCH=perplexity/sonar-reasoning

# Vercel Blob (anexos do chat)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Backend Agno / API (ajuste à URL do seu serviço)
# Local: http://localhost:8000/api/v1
# Produção: https://your-api.example.com/api/v1
