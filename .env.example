# Neon Postgres (use o pooler na aplicação)
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Neon Auth (Console Neon → Auth → Configuration)
# Ex.: https://ep-xxx.neonauth.<region>.aws.neon.tech/<database>/auth
# JWKS do emissor: <NEON_AUTH_BASE_URL>/.well-known/jwks.json
NEON_AUTH_BASE_URL=

# URL pública do CLIENT — deve ser a URL da PRÓPRIA APLICAÇÃO (não o servidor Neon).
# O browser faz as chamadas de auth para /api/auth/[...path] (proxy local),
# que repassa para NEON_AUTH_BASE_URL. Isso garante que os cookies de sessão
# fiquem no domínio correto da aplicação.
# Dev local: http://localhost:3000
# Produção:  https://seu-app.vercel.app  (ou domínio customizado)
NEXT_PUBLIC_NEON_AUTH_BASE_URL=

# URL pública (links, auth redirect) — mesmo valor em geral
NEXT_PUBLIC_SITE_URL=
APP_URL=

# Segredo para cookies (mín. 32 caracteres): openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=

# OpenRouter — chat, embeddings e outros fluxos
OPENROUTER_API_KEY=

# Opcional: chave só para Med Vision (análise de radiografia/tomografia em /api/vision/analyze).
# Se vazia, usa OPENROUTER_API_KEY.
MEDVISION_OPENROUTER_API_KEY=

# Med Vision — saída estruturada (generateObject) quando suportado; defina 0 para desligar.
# MEDVISION_STRUCTURED_OUTPUT=0

# Heurística que extrai "findings" por regex no texto do laudo (desligada por padrão; pode gerar falsos positivos).
# MEDVISION_EXTRACT_FINDINGS_FROM_REPORT=1

# Normalização de imagem (EXIF + resize) antes da análise; defina 1 para desligar.
# MEDVISION_DISABLE_IMAGE_NORMALIZE=1

# Sentry — projeto "medvision" na org insightfy-dr (Client Keys / DSN)
# NEXT_PUBLIC_SENTRY_DSN=  (obrigatório para enviar eventos do browser)
# SENTRY_DSN=             (opcional no servidor; se vazio, usa NEXT_PUBLIC_SENTRY_DSN)
# SENTRY_AUTH_TOKEN=      (build: upload de source maps; escopos project:releases, org:read, project:read)
# Região US: se o upload falhar, defina SENTRY_URL=https://us.sentry.io

# Vercel Cron: protege GET /api/cron/* — a plataforma envia Authorization: Bearer <valor>
# Gere: openssl rand -base64 32
CRON_SECRET=

# Legado removido após migração completa — não usar em novos deploys
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
