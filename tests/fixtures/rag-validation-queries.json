  "scoringRubric": {
    "5": "Highly relevant: Top result directly answers query with correct content from expected source",
    "4": "Very relevant: Top 3 results contain accurate answer with good context",
    "3": "Moderately relevant: Answer found but mixed with less relevant results",
    "2": "Poorly relevant: Some related content but missing key information",
    "1": "Not relevant: Results do not address the query adequately",
    "0": "No results or completely irrelevant"
  },
  "validationMetrics": {
    "target_accuracy": 0.85,
    "description": "At least 85% of queries should return relevant results (score ≥ 3) in top 3 positions",
    "minimumPassRate": 0.75,
    "description_min": "Minimum acceptable: 75% of queries with relevant results"
  },
  "testingProcedure": [
    "1. Execute each query against rag-search Edge Function",
    "2. Review top 3 results for relevance and accuracy",
    "3. Score each query using the rubric (0-5)",
    "4. Check if expected keywords appear in results",
    "5. Verify source documents match expectations",
    "6. Calculate overall accuracy: (scores ≥3) / total queries",
    "7. Document any systematic issues (e.g., specialty bias, keyword failures)",
    "8. Create improvement plan if accuracy < 85%"
  ]
}
