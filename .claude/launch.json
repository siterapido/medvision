{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["iniciar-odontogpt/dev.sh"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "Next.js Dev (port 3001)",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["iniciar-odontogpt/dev-3001.sh"],
      "port": 3001,
      "autoPort": false
    },
    {
      "name": "Next.js Start (Production)",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["node_modules/.bin/next", "start"],
      "port": 3000,
      "autoPort": false
    }
  ]
}
