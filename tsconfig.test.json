{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".tmp/test-run",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true
  },
  "include": [
    "lib/course/helpers.ts",
    "lib/dashboard/overview.ts",
    "components/layout/**/*.tsx",
    "components/courses/**/*.tsx",
    "tests/*.test.ts",
    "tests/*.test.tsx"
  ]
}
