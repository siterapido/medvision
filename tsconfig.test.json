{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".tmp/test-run",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true
  },
  "exclude": [
    "node_modules",
    "supabase/functions",
    "tests-e2e"
  ],
  "include": [
    "lib/ai/openrouter.ts",
    "lib/vision/model-fallback.ts",
    "lib/course/helpers.ts",
    "lib/dashboard/overview.ts",
    "components/layout/**/*.tsx",
    "components/courses/**/*.tsx",
    "tests/vision-default-model.test.ts",
    "tests/vision-model-chain.test.ts",
    "tests/vision-quick-detection-schema.test.ts",
    "tests/vision-specialties.test.ts",
    "tests/vision-analysis-context.test.ts",
    "tests/vision-wizard-state.test.ts",
    "components/vision/med-vision/vision-wizard-state.ts",
    "lib/constants/vision-analysis-options.ts",
    "lib/types/vision-analysis-request.ts",
    "lib/vision/build-analysis-context.ts",
    "lib/vision/json-utils.ts",
    "lib/constants/vision-specialties.ts",
    "lib/constants/vision-specialties/**/*.ts",
    "lib/vision/schemas.ts"
  ]
}
